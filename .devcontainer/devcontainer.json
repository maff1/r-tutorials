{
  "name": "quarto-r",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "customizations": {
    "vscode": {
      "extensions": [
        "quarto.quarto",
        "REditorSupport.r"
      ]
    }
  },

  "remoteEnv": {
    "QUARTO_R": "/usr/bin/R"
  },

  "postCreateCommand": "quarto check"
}